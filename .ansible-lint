skip_list:
  - no-tabs  # Most files should not contain tabs
  - name[casing]
  - risky-shell-pipe
  - no-changed-when
  - var-naming[no-role-prefix] # TODO
  - yaml[indentation]
  - yaml[braces]
  - galaxy[no-changelog]
  - schema[meta-runtime]
  - yaml[empty-lines]

# otherwise ansible-lint scans the roles/collections from requirements.yml
exclude_paths:
  - ansible_collections/community
  - ansible_collections/ansible
  - ansible_collections/general
  - roles/
  - tasks/
